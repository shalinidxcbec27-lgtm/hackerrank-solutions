#include <stdio.h>
int max_of_four(int a, int b, int c, int d){
    int max_num = a;
    if(max_num < b) max_num = b;
    if(max_num < c) max_num = c;
    if(max_num < d) max_num = d;
    
    return max_num;
}
int main() {
    int a, b, c, d;
    scanf("%d %d %d %d", &a, &b, &c, &d);
    int ans = max_of_four(a, b, c, d);
    printf("%d", ans);
    
    return 0;
}
